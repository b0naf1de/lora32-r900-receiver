#pragma once
// Copy this file to secrets.h. It is gitignored.
//
// These are OPTIONAL compile-time DEFAULTS. You can leave them blank and configure everything at
// runtime through the captive portal instead (the board hosts a "R900-Reader-Setup" WiFi AP on
// first boot, or when you double-tap the RST button). Values entered in the portal are
// saved to flash and override anything here.
//
// If you DO fill these in, the board will use them on first boot without needing the portal.

#define WLAN_SSID       ""   // WiFi SSID  (blank -> set via portal)
#define WLAN_PASS       ""   // WiFi password

#define AIO_SERVER      ""   // MQTT broker IP/host (blank -> set via portal)
#define AIO_SERVERPORT  1883 // MQTT port
#define AIO_USERNAME    ""   // MQTT username
#define AIO_KEY         ""   // MQTT password

#define MY_METER_ID     0u   // optional: seed the watch-list + preferred meter (0 = watch/show all meters)
