#pragma once
// Copy this file to secrets.h and fill in your own values. secrets.h is gitignored.

#define WLAN_SSID       "your-wifi-ssid"
#define WLAN_PASS       "your-wifi-password"

// MQTT broker (e.g. the Mosquitto add-on / broker that Home Assistant uses)
#define AIO_SERVER      "192.168.1.80"   // broker IP or hostname
#define AIO_SERVERPORT  1883             // plaintext MQTT port
#define AIO_USERNAME    "mqttuser"       // MQTT username
#define AIO_KEY         "mqttpassword"   // MQTT password

// The Neptune R900 meter the OLED tracks (leak / last-reading display).
// Find it printed on the meter face, or read it from rtl_433 / rtlamr.
// Leave 0 to just show "waiting for meter" until you know it.
#define MY_METER_ID     0u
